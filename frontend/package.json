{
  "name": "vue-course-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json",
    "test:unit": "vitest run",
    "test": "npm run typecheck && npm run test:unit && npm run build",
    "build": "vue-tsc --noEmit -p tsconfig.json && vite build --config vite.config.ts",
    "preview": "vite preview"
  },
  "dependencies": {
    "pinia": "^2.2.6",
    "vue": "^3.5.13",
    "vue-router": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@vitejs/plugin-vue": "^5.2.2",
    "@vue/test-utils": "^2.4.10",
    "jsdom": "^29.1.1",
    "typescript": "^5.8.3",
    "vite": "^6.2.2",
    "vitest": "^4.1.6",
    "vue-tsc": "^2.2.10"
  }
}
